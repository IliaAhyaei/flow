# North Financial Navigator — Environment Variables
# Copy this file to .env and fill in values

# ─── Required: Anthropic API (for AI Advisor chat feature)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: API server port (default: 3001)
# API_PORT=3001

# ─── Optional: Supabase (for production persistence)
# The app works with localStorage by default — no setup needed.
# Uncomment and fill these to enable cloud sync:

# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here
